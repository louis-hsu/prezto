setopt cdablevars                                   # Set default zsh options (setopt) -- Louis 2018/1224

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
    source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

source virtualenvwrapper.sh                         # Configure python virtualenvwrapper -- Louis 2017/0125
#source ~/.tmuxinator/tmuxinator.zsh                 # For tmuxinator auto completion -- Louis 2015/0203

