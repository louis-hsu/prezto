# ---------------------- Alias/Function
# Move alias definitions to separted file (.zsh_aliases) -- Louis 2018/0830
if [ -f ~/.zsh_aliases ]; then
    . ~/.zsh_aliases
fi

precmd() {print ""}

# fzf integration -- Louis 2021/0523
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

