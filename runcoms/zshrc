# Add autocompletion of pipenv -- Louis 2018/0730
if which pipenv > /dev/null; then eval "$(pipenv --completion)" > /dev/null; fi

# ------------------------ Alias/Function
# Move alias definitions to separted file (.zsh_aliases) -- Louis 2018/0830
if [ -f ~/.zsh_aliases ]; then
    . ~/.zsh_aliases
fi

precmd() {print ""}

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh              # fzf integration -- Louis 2021/0523

# Color setup of auto suggestions. No work if setup in zprofile -- Louis 2022/0109
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#878787"

