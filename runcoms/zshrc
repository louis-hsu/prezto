# don't put duplicate lines in the history. See bash(1) for more options
# ... or force ignoredups and ignorespace
HISTCONTROL=ignoredups:ignorespace

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=1000
HISTFILESIZE=2000

# Set default zsh options (setopt) -- Louis 2018/1224
setopt cdablevars

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
    source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# ---------------------- Export
export LSCOLORS=exfxcxdxbxegedabagacad
export EDITOR=vim

# Configure python virtualenvwrapper -- Louis 2017/0125
export WORKON_HOME=$HOME/.virtualenvs
if [[ "$OSTYPE" == "darwin"* ]]; then
    export PROJECT_HOME=$HOME/Development/PythonDev
    source /usr/local/bin/virtualenvwrapper.sh
else
    export PROJECT_HOME=$HOME/PythonDev
    # fix "virtualenvwrapper_run_hook:12: permission denied" issue -- Louis 2018/0704
    export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
    source ~/.local/bin/virtualenvwrapper.sh
fi

# Separate macOS/Ubuntu setup -- Louis 2018/0603
if [[ "$OSTYPE" == "darwin"* ]]; then
    # Android SDK path -- Louis 2011/0420
    export PATH=${PATH}:~/Applications/ADT/tools:~/Applications/ADT/platform-tools
    # Ruby/gem configuration -- Louis 2015/0203
    # Since OS X 'locks' gem packages in /Library/Ruby/Gems with root privilege, I cannot install gem packages
    # with my own account unless run 'sudo', which is a bad idea
    # Install rbenv instead to create private Ruby environment to fix this issue
    #if which rbenv > /dev/null; then eval "$(rbenv init -)"; fi

    # Since no intention to install multi-version Ruby,just export brew-version Ruby
    # Also setup GEM_HOME and gem binary path
    # -- Louis 2018/1220
    export GEM_HOME=~/.gem
    export PATH="/usr/local/opt/ruby/bin:$GEM_HOME/bin:$PATH"

    # For tmuxinator auto completion -- Louis 2015/0203
    source ~/.tmuxinator/tmuxinator.zsh

    # Install brew-version coreutilis -- Louis 2015/0209
    export PATH=/usr/local/opt/coreutils/libexec/gnubin:${PATH}
    export MANPATH=/usr/local/opt/coreutils/libexec/gnuman:${MANPATH}

    # Update brew Python location
    export PATH=/usr/local/opt/python/libexec/bin:${PATH}

    # Update brew sqlite location
    export PATH=/usr/local/opt/sqlite/bin:${PATH}

    # Install jenv for Java version control -- Louis 2016/0905
    export PATH="$HOME/.jenv/bin:$PATH"
    if which jenv > /dev/null; then eval "$(jenv init -)"; fi
else
    # Add snap package binary into $PATH -- Louis 2018/0710
    export PATH=/snap/bin:${PATH}
fi

# Add autocompletion of pipenv -- Louis 2018/0730
if which pipenv > /dev/null; then eval "$(pipenv --completion)" > /dev/null; fi

# ---------------------- Alias
# Move alias definitions to separted file (.zsh_aliases) -- Louis 2018/0830
if [ -f ~/.zsh_aliases ]; then
    . ~/.zsh_aliases
fi

# ---------------------- Function
# Add extract() function to facilitate extract action -- Louis 2015/0311
extract() {
    if [ -f $1 ]; then
        case $1 in
            *.tar.bz2)  tar xjf $1      ;;
            *.tar.gz)   tar xzf $1      ;;
            *.bz2)      bunzip2 $1      ;;
            *.rar)      unrar e $1      ;;
            *.gz)       gunzip $1       ;;
            *.tar)      tar xf $1       ;;
            *.tbz2)     tar xjf $1      ;;
            *.tgz)      tar xzf $1      ;;
            *.zip)      unzip $1        ;;
            *.Z)        uncompress $1   ;;
            *)          echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
       echo "'$1' is not a valid file"
    fi
}

# Add smartresize() function to resize image file(s) by utilizing ImageMagick -- Louis 2015/0629
# smartresize $INPUT_FILE $EXPECTED_WIDTH $OUTPUT_PATH
smartresize() {
    mogrify -path $3 -filter Triangle -define filter:support=2 -thumbnail $2 -unsharp 0.25x0.08+8.3+0.045 -dither None -posterize 136 -quality 82 -define jpeg:fancy-upsampling=off -define png:compression-filter=5 -define png:compression-level=9 -define png:compression-strategy=1 -define png:exclude-chunk=all -interlace none -colorspace sRGB $1
}

