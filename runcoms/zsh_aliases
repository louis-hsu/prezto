# Instead of prefix 'tp*' (as tmux popup/floating session), create function 'tp' to be more
# intuitive and avoid zsh auto command correction behavior
# -- Louis 2023-08-02 17:30
tp() {
  tmux popup -d "#{pane_current_path}" -h 80% -w 80% -e LESS='-i -M -R -W -X -z-4 -g -j4' -e BAT_PAGER='less -R' -E "$@"
}

# Function to switch different neovim configurations
# Refer to:
# https://gist.github.com/elijahmanor/b279553c0132bfad7eae23e34ceb593b
# https://michaeluloth.com/neovim-switch-configs/
# -- Louis 2023/1213
function nvims() {
  #items=$(find -L $HOME/.config -maxdepth 2 -name "init.lua" -type f -execdir sh -c 'pwd | xargs basename' \;)
  # Switch to 'fd'
  items=$(fd --max-depth=1 --glob 'nvim*' ~/.config -x echo {/})

  selected=$(printf "%s\n" "${items[@]}" | FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS-} --preview-window 'right:border-left:50%:<40(right:border-left:50%:hidden)' --preview 'eza -A -T -L 1 --color=always ~/.config/{} | head -200'" fzf --prompt="  Neovim Config 󰄾 ")
  if [[ -z $selected ]]; then
    return 0
  elif [[ $selected == "nvim" ]]; then
    selected=""
  fi
  NVIM_APPNAME=$selected nvim "$@"
}

alias nvs=nvims

# Create aliases for different nvim distros dynamically -- Louis 2023/1213
function create_nvimalias() {
  items=("${(@f)$(fd --max-depth=1 --glob 'nvim*' ~/.config -x echo {/})}")

  for na in $items; do
    if [[ $na != "nvim" ]]; then
      alias "$na"="NVIM_APPNAME=$na nvim"
    fi
  done
}
create_nvimalias

